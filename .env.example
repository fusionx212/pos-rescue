# POS Rescue — environment secrets
# Duplicate as .env.local with real values. Never commit .env.local.

# Stripe (live)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe (test — use for local dev)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_CONNECT_CLIENT_ID=ca_test_...
# STRIPE_WEBHOOK_SECRET=whsec_test_...

# Stripe Connect client ID (public — used by browser for OAuth redirect)
NEXT_PUBLIC_STRIPE_CONNECT_CLIENT_ID=ca_...

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... (service_role, secret)

# Supabase public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (anon, public)